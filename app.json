{
  "expo": {
    "name": "SokSok Voca",
    "slug": "soksok-voca",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "soksokvoca",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1B6EF3"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.soksokvoca",
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "Allow SokSok Voca to use speech recognition for voice input.",
        "NSMicrophoneUsageDescription": "Allow SokSok Voca to use the microphone for voice input."
      }
    },
    "android": {
      "package": "com.soksokvoca",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#1B6EF3",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      [
        "expo-font",
        {
          "fonts": []
        }
      ],
      "@react-native-google-signin/google-signin",
      "expo-web-browser",
      "expo-sqlite",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow SokSok Voca to use the microphone for voice input.",
          "speechRecognitionPermission": "Allow SokSok Voca to use speech recognition for voice input."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {
        "origin": "https://replit.com/"
      },
      "eas": {
        "projectId": "2d560de2-a41b-4ac1-a019-d287f7aaa2d6"
      }
    }
  }
}
