{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Expo (Frontend)",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["start"],
      "port": 8081
    },
    {
      "name": "Express (Backend)",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["run", "server:dev"],
      "port": 5000
    },
    {
      "name": "Full Stack (Frontend + Backend)",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["dev"],
      "port": 8081,
      "autoPort": true
    }
  ]
}
